{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/preload/*.d.ts",
    "src/shared/**/*",
    "../../packages/validations/src/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["src/renderer/src/*"],
      "@freestyle/sdk": ["../../packages/sdk/src/index.ts"],
      "@freestyle/server": ["../server/src/index.ts"],
      "@freestyle/utils": ["../../packages/utils/src/index.ts"],
      "@freestyle/validations": ["../../packages/validations/src/index.ts"]
    }
  }
}

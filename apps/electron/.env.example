# Example local development env for the desktop app.
#
# Copy this file to `.env.local` (which is gitignored) and adjust as needed.
# In development, the Electron main process loads `.env.local` at startup
# (apps/electron/src/main/index.ts) and the embedded server inherits these
# values via process.env. This file is NOT loaded in packaged/production builds.

# Enable PostHog analytics while running `pnpm dev` so you can exercise the
# onboarding funnel locally. Events are tagged environment=development in
# PostHog; filter to environment=production for real analysis. Optional.
FREESTYLE_ANALYTICS_DEV=1

# Base URL of the Freestyle Cloud backend used by server-owned auth,
# transcription, and cleanup. Leave unset to use the hosted default baked into
# apps/server; set it only when testing against a locally running cloud Worker.
#
# This is the cloud Worker's `wrangler dev` URL (run from the `cloud` repo),
# NOT the Freestyle server (which listens on 4649). Electron loads this file in
# dev and the embedded server inherits the value via process.env. Confirm the
# port wrangler prints on startup — 8787 is the Cloudflare default. Optional.
FREESTYLE_CLOUD_URL=http://localhost:8787

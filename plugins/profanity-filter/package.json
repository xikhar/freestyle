{
  "name": "@freestyle-voice/profanity-filter",
  "version": "0.1.0",
  "type": "module",
  "description": "Swap curse words for wholesome, funnier stand-ins as you dictate.",
  "license": "MIT",
  "homepage": "https://github.com/freestyle-voice/freestyle/tree/main/plugins/profanity-filter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freestyle-voice/freestyle.git",
    "directory": "plugins/profanity-filter"
  },
  "keywords": [
    "freestyle",
    "freestyle-plugin",
    "voice",
    "dictation",
    "profanity"
  ],
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "freestyle": {
    "icon": "Sparkles",
    "contributes": {
      "pages": [
        {
          "id": "profanity-filter",
          "title": "Profanity Filter",
          "entry": "dist/ui/index.html"
        }
      ]
    }
  },
  "scripts": {
    "build": "pkgroll --minify && vite build",
    "typecheck": "tsc --noEmit && tsc --noEmit -p ui/tsconfig.json"
  },
  "dependencies": {
    "freestyle-voice": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "hono": "^4.12.22",
    "pkgroll": "^2.27.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.8.3",
    "vite": "^7.3.3"
  }
}
